# Public URL of the deployed site
NEXT_PUBLIC_SITE_URL=https://novasoft.example

# Default locale for localized routing (en or fr)
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Optional domain name for Plausible analytics tracking
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Contact form email recipients (falls back to content/site.json contact email)
CONTACT_TO_EMAIL=hello@novasoft.example
# Optional default "from" address if different from the recipient
CONTACT_FROM_EMAIL=website@novasoft.example

# Resend configuration (leave blank if using SMTP)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@novasoft.example

# SMTP configuration (leave blank if using Resend)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false

# Bot protection (choose either hCaptcha or Cloudflare Turnstile; set both secret and site key to enable)
HCAPTCHA_SECRET=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
TURNSTILE_SECRET=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Optional webhook to push submissions to Google Sheets or other integrations
SHEET_WEBHOOK_URL=
